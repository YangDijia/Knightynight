# Postgres connection string
DATABASE_URL=postgresql://knightynight:replace_me@127.0.0.1:5432/knightynight

# API server
PORT=3000
NODE_ENV=production

# Frontend origin, comma-separated if multiple
CORS_ORIGINS=https://your-domain.com

# Optional token auth for all write APIs
# If empty, auth check is skipped (not recommended in production)
API_WRITE_TOKEN=replace_with_strong_random_token
